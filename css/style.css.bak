/* ===== 基础样式 ===== */
:root {
  --primary: #4A90D9;
  --primary-dark: #357ABD;
  --secondary: #27AE60;
  --accent: #F39C12;
  --danger: #E74C3C;
  --bg: #F5F7FA;
  --card-bg: #FFFFFF;
  --text: #2C3E50;
  --text-light: #7F8C8D;
  --border: #E1E8ED;
  --shadow: 0 2px 12px rgba(0,0,0,0.08);
  --shadow-hover: 0 8px 24px rgba(0,0,0,0.12);
  --radius: 16px;
  --radius-sm: 8px;
  --transition: all 0.3s ease;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Noto Sans SC', 'Nunito', -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  line-height: 1.6;
}

/* ===== 导航栏 ===== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 64px;
  background: var(--card-bg);
  box-shadow: var(--shadow);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32px;
  z-index: 1000;
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 22px;
  font-weight: 800;
  color: var(--primary);
}

.logo {
  font-size: 28px;
}

.nav-links {
  display: flex;
  gap: 8px;
}

.nav-link {
  padding: 8px 18px;
  border-radius: 20px;
  text-decoration: none;
  color: var(--text-light);
  font-weight: 500;
  font-size: 15px;
  transition: var(--transition);
}

.nav-link:hover,
.nav-link.active {
  background: rgba(74, 144, 217, 0.1);
  color: var(--primary);
}

.nav-stats {
  display: flex;
  gap: 20px;
  font-size: 14px;
  color: var(--text-light);
  align-items: center;
}

.stat-item {
  background: var(--bg);
  padding: 6px 14px;
  border-radius: 20px;
  font-weight: 600;
}

/* ===== 用户区域 ===== */
#user-area .user-info {
  display: flex;
  align-items: center;
  gap: 10px;
}

.user-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 14px;
}

.user-name {
  font-weight: 600;
  color: var(--text);
}

.user-menu-btn {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 16px;
  padding: 4px;
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2500;
  animation: fadeIn 0.3s ease;
  padding: 20px;
}

.modal-box {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 32px;
  width: 100%;
  max-width: 420px;
  position: relative;
  animation: slideUp 0.3s ease;
}

.modal-wide {
  max-width: 560px;
}

.modal-close {
  position: absolute;
  top: 16px;
  right: 20px;
  background: none;
  border: none;
  font-size: 24px;
  color: var(--text-light);
  cursor: pointer;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: var(--transition);
}

.modal-close:hover {
  background: var(--bg);
  color: var(--danger);
}

.modal-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  border-bottom: 2px solid var(--border);
  padding-bottom: 12px;
}

.modal-tab {
  flex: 1;
  padding: 10px;
  background: none;
  border: none;
  font-family: inherit;
  font-size: 16px;
  font-weight: 600;
  color: var(--text-light);
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: var(--transition);
}

.modal-tab:hover {
  background: var(--bg);
}

.modal-tab.active {
  color: var(--primary);
  background: rgba(74, 144, 217, 0.1);
}

.modal-input {
  width: 100%;
  padding: 14px 16px;
  margin-bottom: 14px;
  border: 2px solid var(--border);
  border-radius: var(--radius-sm);
  font-family: inherit;
  font-size: 15px;
  transition: var(--transition);
}

.modal-input:focus {
  outline: none;
  border-color: var(--primary);
}

.modal-error {
  color: var(--danger);
  font-size: 14px;
  margin-top: 12px;
  min-height: 20px;
  text-align: center;
}

/* 排行榜 */
.leaderboard-list {
  max-height: 400px;
  overflow-y: auto;
}

.lb-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 14px 16px;
  border-radius: var(--radius-sm);
  transition: var(--transition);
}

.lb-item:hover {
  background: var(--bg);
}

.lb-rank {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 14px;
  flex-shrink: 0;
}

.lb-rank.gold { background: #FFF8E1; color: #F9A825; }
.lb-rank.silver { background: #F5F5F5; color: #757575; }
.lb-rank.bronze { background: #FBE9E7; color: #D84315; }
.lb-rank.normal { background: var(--bg); color: var(--text-light); }

.lb-info {
  flex: 1;
}

.lb-name {
  font-weight: 600;
  font-size: 15px;
}

.lb-meta {
  font-size: 13px;
  color: var(--text-light);
}

.lb-score {
  font-weight: 800;
  font-size: 18px;
  color: var(--accent);
}

/* ===== 页面容器 ===== */
.main-content {
  padding-top: 84px;
  max-width: 1200px;
  margin: 0 auto;
  padding-left: 24px;
  padding-right: 24px;
  padding-bottom: 60px;
}

.page {
  display: none;
  animation: fadeIn 0.4s ease;
}

.page.active {
  display: block;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== 首页 Hero ===== */
.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60px 0 50px;
  gap: 40px;
}

.hero-content {
  flex: 1;
}

.hero-content h1 {
  font-size: 48px;
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16px;
}

.highlight {
  color: var(--primary);
  position: relative;
}

.highlight::after {
  content: '';
  position: absolute;
  bottom: 4px;
  left: 0;
  right: 0;
  height: 10px;
  background: rgba(74, 144, 217, 0.2);
  border-radius: 4px;
  z-index: -1;
}

.hero-subtitle {
  font-size: 18px;
  color: var(--text-light);
  margin-bottom: 32px;
}

.hero-buttons {
  display: flex;
  gap: 16px;
}

.hero-visual {
  flex-shrink: 0;
}

.word-puzzle-demo {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--card-bg);
  padding: 28px 36px;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.puzzle-piece {
  padding: 12px 20px;
  border-radius: var(--radius-sm);
  font-weight: 700;
  font-size: 18px;
  animation: bounceIn 0.8s ease;
}

.puzzle-piece.prefix {
  background: #FFF3E0;
  color: #E65100;
}

.puzzle-piece.root {
  background: #E3F2FD;
  color: #1565C0;
}

.puzzle-arrow {
  font-size: 24px;
  color: var(--text-light);
}

.puzzle-result {
  padding: 12px 24px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
  border-radius: var(--radius-sm);
  font-weight: 800;
  font-size: 20px;
  animation: pulse 2s infinite;
}

@keyframes bounceIn {
  0% { transform: scale(0.3); opacity: 0; }
  50% { transform: scale(1.05); }
  70% { transform: scale(0.9); }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

/* ===== 仪表盘 ===== */
.dashboard {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
  margin-bottom: 48px;
}

.dash-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 28px;
  text-align: center;
  box-shadow: var(--shadow);
  transition: var(--transition);
  cursor: pointer;
}

.dash-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-hover);
}

.dash-icon {
  font-size: 36px;
  margin-bottom: 8px;
}

.dash-number {
  font-size: 32px;
  font-weight: 800;
  color: var(--primary);
}

.dash-label {
  font-size: 14px;
  color: var(--text-light);
  margin-top: 4px;
}

/* ===== 区块标题 ===== */
.section-title {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title .link-btn {
  font-size: 14px;
  color: var(--primary);
  cursor: pointer;
  font-weight: 600;
}

.section-title .link-btn:hover {
  text-decoration: underline;
}

/* ===== 词根展示 ===== */
.root-showcase {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 20px;
}

.root-item {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 24px;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: var(--transition);
  border-left: 4px solid transparent;
}

.root-item:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-hover);
}

.root-name {
  font-size: 24px;
  font-weight: 800;
  margin-bottom: 8px;
}

.root-meaning {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 12px;
}

.root-words {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.root-word-tag {
  background: var(--bg);
  padding: 4px 10px;
  border-radius: 12px;
  font-size: 13px;
  color: var(--text);
}

/* ===== 按钮 ===== */
.btn {
  padding: 12px 28px;
  border: none;
  border-radius: var(--radius-sm);
  font-size: 16px;
  font-weight: 600;
  font-family: inherit;
  cursor: pointer;
  transition: var(--transition);
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
  box-shadow: 0 4px 12px rgba(74, 144, 217, 0.3);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(74, 144, 217, 0.4);
}

.btn-secondary {
  background: var(--card-bg);
  color: var(--text);
  border: 2px solid var(--border);
}

.btn-secondary:hover {
  border-color: var(--primary);
  color: var(--primary);
}

.btn-outline {
  background: transparent;
  color: var(--text-light);
  border: 1px solid var(--border);
}

.btn-outline:hover {
  color: var(--primary);
  border-color: var(--primary);
}

.btn-small {
  padding: 8px 16px;
  font-size: 14px;
}

.btn-icon {
  background: var(--bg);
  border: none;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  font-size: 18px;
  cursor: pointer;
  transition: var(--transition);
}

.btn-icon:hover {
  background: var(--primary);
  transform: scale(1.1);
}

/* ===== 词根学习页面 ===== */
.learn-header,
.context-header,
.games-header {
  text-align: center;
  padding: 30px 0;
}

.learn-header h2,
.context-header h2,
.games-header h2 {
  font-size: 32px;
  margin-bottom: 8px;
}

.learn-header p,
.context-header p,
.games-header p {
  color: var(--text-light);
  font-size: 16px;
}

.learn-container {
  display: flex;
  gap: 24px;
}

.root-sidebar {
  width: 240px;
  flex-shrink: 0;
  max-height: calc(100vh - 200px);
  display: flex;
  flex-direction: column;
}

.sidebar-title {
  font-weight: 700;
  font-size: 16px;
  margin-bottom: 16px;
  padding-left: 8px;
}

.root-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  overflow-y: auto;
  max-height: calc(100vh - 240px);
  padding-right: 8px;
}

.root-list::-webkit-scrollbar {
  width: 6px;
}

.root-list::-webkit-scrollbar-track {
  background: transparent;
}

.root-list::-webkit-scrollbar-thumb {
  background: var(--border);
  border-radius: 3px;
}

.root-list::-webkit-scrollbar-thumb:hover {
  background: var(--text-light);
}

.root-btn {
  padding: 14px 18px;
  background: var(--card-bg);
  border: 2px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  text-align: left;
  font-family: inherit;
  font-size: 15px;
  font-weight: 600;
  transition: var(--transition);
  display: flex;
  align-items: center;
  gap: 10px;
}

.root-btn:hover {
  border-color: var(--primary);
  color: var(--primary);
}

.root-btn.active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

.root-btn .root-color-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.word-display {
  flex: 1;
}

.word-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 28px;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
}

.word-badge {
  font-size: 14px;
  opacity: 0.9;
}

.card-body {
  padding: 32px;
}

.word-main {
  font-size: 42px;
  font-weight: 800;
  color: var(--primary);
  margin-bottom: 4px;
}

.word-phonetic {
  font-size: 18px;
  color: var(--text-light);
  font-family: 'Nunito', sans-serif;
  margin-bottom: 8px;
}

.word-meaning {
  font-size: 22px;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 28px;
}

/* 词根拆解 */
.breakdown-section,
.examples-section {
  margin-bottom: 28px;
}

.breakdown-title,
.examples-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 16px;
  color: var(--text);
}

.breakdown-parts {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
  flex-wrap: wrap;
}

.part-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 20px;
  border-radius: var(--radius-sm);
  min-width: 80px;
  animation: slideUp 0.4s ease backwards;
}

.part-item:nth-child(1) { animation-delay: 0.1s; }
.part-item:nth-child(2) { animation-delay: 0.2s; }
.part-item:nth-child(3) { animation-delay: 0.3s; }

@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.part-item.prefix {
  background: #FFF3E0;
  color: #E65100;
}

.part-item.root {
  background: #E3F2FD;
  color: #1565C0;
  border: 2px solid var(--primary);
}

.part-item.suffix {
  background: #F3E5F5;
  color: #7B1FA2;
}

.part-text {
  font-size: 22px;
  font-weight: 800;
  margin-bottom: 4px;
}

.part-type {
  font-size: 12px;
  opacity: 0.7;
  margin-bottom: 2px;
}

.part-meaning {
  font-size: 13px;
  font-weight: 500;
}

.part-plus {
  font-size: 24px;
  color: var(--text-light);
  align-self: center;
  font-weight: 300;
}

.part-equals {
  font-size: 24px;
  color: var(--primary);
  align-self: center;
  font-weight: 700;
}

.root-info {
  background: var(--bg);
  padding: 14px 18px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  gap: 12px;
}

.root-tag {
  background: var(--primary);
  color: white;
  padding: 6px 14px;
  border-radius: 20px;
  font-weight: 700;
  font-size: 15px;
}

.root-desc {
  font-size: 14px;
  color: var(--text-light);
}

/* 例句 */
.examples-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* 词根家族 */
.family-section {
  margin-top: 28px;
  padding-top: 24px;
  border-top: 1px dashed var(--border);
}

.family-title {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 14px;
  color: var(--text);
}

.family-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.family-tag {
  display: inline-block;
  padding: 6px 12px;
  background: var(--bg);
  border-radius: 20px;
  font-size: 14px;
  color: var(--text);
  transition: var(--transition);
  cursor: pointer;
}

.family-tag:hover {
  background: var(--primary);
  color: white;
}

.family-tag.current {
  background: var(--primary);
  color: white;
  font-weight: 600;
}

.family-count {
  margin-top: 12px;
  font-size: 13px;
  color: var(--text-light);
}

.example-item {
  padding: 18px 20px;
  background: var(--bg);
  border-radius: var(--radius-sm);
  border-left: 3px solid var(--primary);
}

.example-en {
  font-size: 16px;
  color: var(--text);
  margin-bottom: 6px;
  line-height: 1.7;
}

.example-cn {
  font-size: 14px;
  color: var(--text-light);
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 28px;
  border-top: 1px solid var(--border);
  gap: 12px;
}

/* ===== 语境记忆页面 ===== */
.context-container {
  max-width: 800px;
  margin: 0 auto;
}

.context-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 40px;
}

.context-progress {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 32px;
}

.progress-bar {
  flex: 1;
  height: 8px;
  background: var(--bg);
  border-radius: 4px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: 4px;
  transition: width 0.4s ease;
  width: 20%;
}

.progress-text {
  font-size: 14px;
  color: var(--text-light);
  font-weight: 600;
  min-width: 50px;
  text-align: right;
}

.context-word-area {
  text-align: center;
  margin-bottom: 32px;
}

.context-word {
  font-size: 36px;
  font-weight: 800;
  color: var(--primary);
}

.context-phonetic {
  font-size: 16px;
  color: var(--text-light);
  margin-top: 4px;
}

.context-sentence-area {
  margin-bottom: 28px;
}

.context-label {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 12px;
}

.context-sentence {
  font-size: 20px;
  line-height: 1.8;
  padding: 24px;
  background: var(--bg);
  border-radius: var(--radius-sm);
  color: var(--text);
}

.context-sentence .blank {
  display: inline-block;
  min-width: 100px;
  padding: 4px 16px;
  border-bottom: 3px solid var(--primary);
  text-align: center;
  font-weight: 700;
  color: var(--primary);
  transition: var(--transition);
}

.context-translation {
  margin-top: 12px;
  font-size: 15px;
  color: var(--text-light);
  padding: 0 24px;
  opacity: 0;
  transition: opacity 0.4s ease;
}

.context-translation.show {
  opacity: 1;
}

.context-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.option-btn {
  padding: 18px 24px;
  background: var(--card-bg);
  border: 2px solid var(--border);
  border-radius: var(--radius-sm);
  font-family: inherit;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
  text-align: left;
}

.option-btn:hover:not(:disabled) {
  border-color: var(--primary);
  background: rgba(74, 144, 217, 0.05);
}

.option-btn.correct {
  background: #E8F5E9;
  border-color: var(--secondary);
  color: var(--secondary);
}

.option-btn.wrong {
  background: #FFEBEE;
  border-color: var(--danger);
  color: var(--danger);
  animation: shake 0.4s ease;
}

.option-btn:disabled {
  cursor: default;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-8px); }
  75% { transform: translateX(8px); }
}

.context-feedback {
  text-align: center;
  margin-bottom: 20px;
  min-height: 28px;
  font-weight: 600;
  font-size: 16px;
}

.context-feedback.correct {
  color: var(--secondary);
}

.context-feedback.wrong {
  color: var(--danger);
}

.context-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ===== 趣味挑战页面 ===== */
.games-menu {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 40px;
}

.game-card {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 36px 28px;
  text-align: center;
  box-shadow: var(--shadow);
  cursor: pointer;
  transition: var(--transition);
  position: relative;
  overflow: hidden;
}

.game-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow-hover);
}

.game-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--primary), var(--accent));
}

.game-icon {
  font-size: 48px;
  margin-bottom: 16px;
}

.game-title {
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 8px;
}

.game-desc {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 16px;
}

.game-badge {
  display: inline-block;
  background: var(--bg);
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  color: var(--accent);
}

/* ===== 游戏区域 ===== */
.game-area {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 32px;
}

.game-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
}

.game-score {
  font-size: 20px;
  font-weight: 700;
  color: var(--accent);
}

.game-timer {
  font-size: 20px;
  font-weight: 800;
  color: var(--danger);
  font-family: 'Nunito', monospace;
}

.game-content {
  min-height: 300px;
}

/* 词根拼图游戏 */
.puzzle-game {
  text-align: center;
}

.puzzle-target {
  font-size: 18px;
  color: var(--text-light);
  margin-bottom: 20px;
}

.puzzle-target strong {
  color: var(--text);
}

.puzzle-slots {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 40px;
  min-height: 70px;
}

.puzzle-slot {
  width: 120px;
  height: 60px;
  border: 3px dashed var(--border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 700;
  transition: var(--transition);
}

.puzzle-slot.filled {
  border-style: solid;
  border-color: var(--primary);
  background: #E3F2FD;
  color: var(--primary);
}

.puzzle-pieces {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
}

.puzzle-piece-draggable {
  padding: 14px 24px;
  border-radius: var(--radius-sm);
  font-size: 20px;
  font-weight: 700;
  cursor: grab;
  transition: var(--transition);
  user-select: none;
}

.puzzle-piece-draggable:active {
  cursor: grabbing;
}

.puzzle-piece-draggable:hover {
  transform: scale(1.08);
  box-shadow: var(--shadow);
}

.puzzle-piece-draggable.placed {
  opacity: 0.4;
  pointer-events: none;
}

/* 记忆翻牌游戏 */
.memory-game {
  max-width: 600px;
  margin: 0 auto;
}

.memory-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

.memory-card {
  aspect-ratio: 1;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: var(--transition);
  font-size: 28px;
  position: relative;
  transform-style: preserve-3d;
}

.memory-card:hover {
  transform: scale(1.05);
}

.memory-card.flipped {
  background: var(--bg);
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  padding: 12px;
  text-align: center;
}

.memory-card.matched {
  background: #E8F5E9;
  color: var(--secondary);
  animation: matchPulse 0.5s ease;
}

@keyframes matchPulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); }
}

/* 极速词根游戏 */
.speed-game {
  text-align: center;
}

.speed-question {
  font-size: 22px;
  margin-bottom: 32px;
  padding: 24px;
  background: var(--bg);
  border-radius: var(--radius-sm);
}

.speed-question .root-hint {
  display: inline-block;
  background: var(--primary);
  color: white;
  padding: 6px 16px;
  border-radius: 20px;
  font-weight: 700;
  margin: 0 8px;
}

.speed-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  max-width: 500px;
  margin: 0 auto;
}

.speed-option {
  padding: 20px;
  background: var(--card-bg);
  border: 2px solid var(--border);
  border-radius: var(--radius-sm);
  font-family: inherit;
  font-size: 18px;
  font-weight: 600;
  cursor: pointer;
  transition: var(--transition);
}

.speed-option:hover {
  border-color: var(--primary);
  background: rgba(74, 144, 217, 0.05);
}

/* ===== Toast ===== */
.toast {
  position: fixed;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%) translateY(100px);
  background: var(--text);
  color: white;
  padding: 14px 28px;
  border-radius: var(--radius-sm);
  font-size: 15px;
  font-weight: 500;
  opacity: 0;
  transition: all 0.4s ease;
  z-index: 2000;
  pointer-events: none;
}

.toast.show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

/* ===== 庆祝画布 ===== */
#confetti-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 3000;
}

/* ===== 响应式 ===== */
@media (max-width: 900px) {
  .hero {
    flex-direction: column;
    text-align: center;
  }
  
  .hero-content h1 {
    font-size: 32px;
  }
  
  .dashboard {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .learn-container {
    flex-direction: column;
  }
  
  .root-sidebar {
    width: 100%;
    max-height: none;
  }
  
  .root-list {
    flex-direction: row;
    flex-wrap: wrap;
    max-height: 200px;
    overflow-y: auto;
    padding-right: 4px;
  }
  
  .root-btn {
    flex: 1;
    min-width: 100px;
  }
  
  .games-menu {
    grid-template-columns: 1fr;
  }
  
  .memory-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .navbar {
    padding: 0 16px;
  }
  
  .nav-links {
    display: none;
  }
  
  .nav-stats {
    gap: 8px;
  }
  
  .stat-item {
    padding: 4px 10px;
    font-size: 12px;
  }
}

/* ===== 游戏结束弹窗 ===== */
.game-over-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2500;
  animation: fadeIn 0.3s ease;
}

.game-over-modal {
  background: var(--card-bg);
  border-radius: var(--radius);
  padding: 48px;
  text-align: center;
  max-width: 420px;
  width: 90%;
  animation: bounceIn 0.5s ease;
}

.game-over-modal .modal-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.game-over-modal .modal-title {
  font-size: 28px;
  font-weight: 800;
  margin-bottom: 8px;
}

.game-over-modal .modal-score {
  font-size: 48px;
  font-weight: 800;
  color: var(--accent);
  margin-bottom: 8px;
}

.game-over-modal .modal-desc {
  color: var(--text-light);
  margin-bottom: 28px;
}
